{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/src/server.js",
    "prisma:push": "pnpm prisma db push",
    "prisma:seed": "tsx --env-file=.env prisma/seed.ts",
    "ingest": "tsx --env-file=.env src/ingestion/ingest-jobs.ts",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/**/*.ts\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "prettier": "^3.8.1",
    "prisma": "^7.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "ioredis": "^5.10.1",
    "node-cron": "^4.2.1",
    "pg": "^8.18.0"
  }
}