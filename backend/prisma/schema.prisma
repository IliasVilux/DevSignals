// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["typedSql"]
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum RemoteType {
  ONSITE
  HYBRID
  REMOTE
}

enum SkillCategory {
  LANGUAGE
  FRAMEWORK
  DATABASE
  DEVOPS
  CLOUD
  OTHER
}

enum SkillLevel {
  BASIC
  INTERMEDIATE
  ADVANCED
}

// ─── Market / ingestion domain ────────────────────────────────────────────────

model Country {
  id             String    @id @default(cuid())
  name           String    @unique
  code           String    @unique
  lastIngestedAt DateTime?
  jobs           Job[]
}

model Job {
  id          String     @id @default(cuid())
  externalId  String
  role        String
  description String?
  company     String?
  salaryMin   Int?
  salaryMax   Int?
  remoteType  RemoteType
  postedAt    DateTime
  country     Country    @relation(fields: [countryId], references: [id])
  countryId   String
  createdAt   DateTime   @default(now())
  skills      JobSkill[]

  @@unique([externalId, countryId])
  @@index([countryId, role])
  @@index([postedAt])
}

model JobSkill {
  job      Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId    String
  skill    Skill  @relation(fields: [skillId], references: [id])
  skillId  String

  @@id([jobId, skillId])
}

// ─── Skills domain ────────────────────────────────────────────────────────────

model Skill {
  id         String        @id @default(cuid())
  name       String        @unique
  category   SkillCategory @default(OTHER)
  jobs       JobSkill[]
  userSkills UserSkill[]
}

// ─── User domain ──────────────────────────────────────────────────────────────

model User {
  id                String      @id @default(cuid())
  provider          String
  providerAccountId String
  email             String
  name              String
  picture           String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  skills            UserSkill[]

  @@unique([provider, providerAccountId])
}

model UserSkill {
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String
  skill   Skill      @relation(fields: [skillId], references: [id])
  skillId String
  level   SkillLevel @default(BASIC)

  @@id([userId, skillId])
}
