// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  previewFeatures = ["typedSql"]
}

datasource db {
  provider = "postgresql"
}

enum RemoteType {
  ONSITE
  HYBRID
  REMOTE
}

enum SkillCategory {
  LANGUAGE
  FRAMEWORK
  DATABASE
  DEVOPS
  CLOUD
  OTHER
}

model Country {
  id       String   @id @default(cuid())
  name     String   @unique
  code     String   @unique
  jobs     Job[]
}

model Job {
  id          String     @id @default(cuid())
  externalId  String
  role        String
  description String?
  company     String?
  salaryMin   Int?
  salaryMax   Int?
  remoteType  RemoteType
  postedAt    DateTime
  country     Country    @relation(fields: [countryId], references: [id])
  countryId   String
  createdAt   DateTime   @default(now())
  skills      JobSkill[]

  @@unique([externalId, countryId])
  @@index([countryId, role])
  @@index([postedAt])
}

model Skill {
  id             String        @id @default(cuid())
  name           String        @unique
  category       SkillCategory @default(OTHER)
  jobs           JobSkill[]
}

model JobSkill {
  job      Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId    String
  skill    Skill  @relation(fields: [skillId], references: [id])
  skillId  String

  @@id([jobId, skillId])
}