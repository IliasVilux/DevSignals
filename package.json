{
  "name": "devsignals",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter backend --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build": "pnpm -r build",
    "build:backend": "pnpm --filter backend build",
    "build:frontend": "pnpm --filter frontend build",
    "test": "pnpm -r test",
    "test:backend": "pnpm --filter backend test",
    "test:frontend": "pnpm --filter frontend test",
    "format": "pnpm -r format",
    "lint": "pnpm --filter frontend lint",
    "lint:fix": "pnpm --filter frontend lint:fix",
    "ingest": "pnpm --filter backend ingest",
    "prisma:push": "pnpm --filter backend prisma:push",
    "prisma:seed": "pnpm --filter backend prisma:seed",
    "prepare": "husky"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@swc/core",
      "esbuild",
      "msw",
      "prisma"
    ]
  },
  "lint-staged": {
    "backend/**/*.ts": "backend/node_modules/.bin/prettier --write",
    "frontend/**/*.{ts,tsx,css}": "frontend/node_modules/.bin/prettier --write"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
